# Database
DATABASE_URL=postgresql+psycopg://loanofficer:loanofficer_password@localhost:5432/loanofficer_mvp

# Auth
JWT_SECRET=change-me

# AWS (Bedrock chat/agents; Textract only when DOCUMENT_PARSER=textract)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
TEXTRACT_REGION=us-east-1

# Document parsing: llamaindex (default) or textract (explicit AWS opt-in)
DOCUMENT_PARSER=llamaindex

# LlamaCloud — Parse + Extract for all supported uploads (free plan: ~10k credits/month)
LLAMA_CLOUD_API_KEY=
LLAMA_PARSE_TIER=cost_effective
LLAMA_EXTRACT_TIER=cost_effective
LLAMA_POLL_INTERVAL_SEC=2.0
LLAMA_JOB_TIMEOUT_SEC=120

# Observability
OBSERVABILITY_PROVIDER=none
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=loan-officer-copilot
OTEL_SERVICE_NAME=loan-officer-copilot
OTEL_EXPORTER_OTLP_ENDPOINT=

# Storage
STORAGE_BACKEND=local
S3_BUCKET=loan-officer-copilot-mvp
LOCAL_STORAGE_DIR=./local_storage

